# =============================================================================
# Sage V — Environment Variables Reference
# Copy this file to .env and fill in your values before starting the platform.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------

# Python environment: "dev" or "prod"
ENVIRONMENT=dev

# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET_KEY=change-me-in-production

# Flush Redis cache on every server startup (set true only for initial dev setup)
FLUSH_CACHE_ON_STARTUP=false

# Maximum concurrent Socket.IO connections per worker (-1 = unlimited)
MAX_SOCKET_CONNECTIONS_PER_WORKER=-1

# Log full request/response data to the log DB (true/false)
LOG_REQUEST_RESPONSE_DATA_FLAG=false

# Semantic version of the platform (also read from VERSION file if present)
APP_VERSION=1.0.0

# Seed the database on startup (true/false)
SEED_DB=false

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------

BACKEND_PORT=5050
FRONTEND_PORT=3000
BACKEND_WORKERS=2

# -----------------------------------------------------------------------------
# CORS (Backend)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS
# Defaults to http://localhost:3000 in dev
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# MongoDB — Application Database
# -----------------------------------------------------------------------------

# Full MongoDB connection string (used by FastAPI server)
APP_DB_CONNECTION_STRING=mongodb://admin:password@localhost:27017/sage_v?authSource=admin

# Application database name
APP_DB_NAME=sage_v

# MongoDB credentials for docker-compose-db.yml
MONGO_APP_DB_USERNAME=admin
MONGO_APP_DB_PASSWORD=password

# Optional: initial admin user password (argon2 hashed)
ADMIN_USER_PASSWORD=

ADMIN_MONGO_PASSWORD=

# -----------------------------------------------------------------------------
# MongoDB — Log / Audit Database
# -----------------------------------------------------------------------------

# Full MongoDB connection string for the log database
LOG_DB_CONNECTION_STRING=mongodb://admin:password@localhost:27017/sage_v_logs?authSource=admin

LOG_DB_NAME=sage_v_logs

MONGO_LOG_DB_USERNAME=admin
MONGO_LOG_DB_PASSWORD=password

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Set to true if Redis requires TLS
REDIS_SECURE=false

# -----------------------------------------------------------------------------
# TimescaleDB (PostgreSQL) — Metering Database
# -----------------------------------------------------------------------------

TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_USER=sage_v
TIMESCALE_PASSWORD=password
TIMESCALE_DATABASE_NAME=sage_v_metering

# -----------------------------------------------------------------------------
# RabbitMQ / Celery
# -----------------------------------------------------------------------------

RABBITMQ_DEFAULT_USER=sage_v
RABBITMQ_DEFAULT_PASS=password
RABBITMQ_DEFAULT_VHOST=sage_v

# Celery broker URL (pyamqp or redis)
CELERY_BROKER_URL=pyamqp://sage_v:password@localhost:5672/sage_v

# API key used by the Celery heartbeat task to call the backend
HEARTBEAT_API_KEY=

# -----------------------------------------------------------------------------
# Celery Flower (task monitor UI)
# -----------------------------------------------------------------------------

CELERY_FLOWER_BROKER_API=http://sage_v:password@localhost:15672/api/
CELERY_FLOWER_ADDRESS=0.0.0.0
CELERY_FLOWER_PORT=5555
FLOWER_LOGGING_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend (Next.js — NEXT_PUBLIC_ vars are exposed to the browser)
# -----------------------------------------------------------------------------

# Base URL of the FastAPI backend, accessible from the browser
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:5050

# Platform API key used for service/model listing calls from the frontend
NEXT_PUBLIC_API_KEY=

# Grafana base URL for embedded dashboards
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Prometheus / Metrics
# -----------------------------------------------------------------------------

PROMETHEUS_URL=http://localhost:9090

# Prometheus Aggregation Gateway credentials
PROM_AGG_GATEWAY_USERNAME=user
PROM_AGG_GATEWAY_PASSWORD=password
PAG_AUTHUSERS=user=password

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_SECURE_COOKIE=false
GRAFANA_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Azure Blob Storage (optional — used for feedback dump uploads)
# -----------------------------------------------------------------------------

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
BLOB_STORE=

# -----------------------------------------------------------------------------
# Email / SMTP (used by Celery send_usage_email task)
# -----------------------------------------------------------------------------

SMTP_SERVER=smtp.example.com
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=
USAGE_EMAIL_SENDER=noreply@example.com
USAGE_EMAIL_RECIPIENTS=admin@example.com

# -----------------------------------------------------------------------------
# External Inference Utilities (optional)
# -----------------------------------------------------------------------------

# Inverse Text Normalization endpoint
ITN_ENDPOINT=
ITN_ENDPOINT_API_KEY=

# Speech utilities endpoint (used by audio_service)
SPEECH_UTILS_ENDPOINT=
SPEECH_UTILS_ENDPOINT_API_KEY=

# VAD model directory path on the inference server
VAD_DIR=

# -----------------------------------------------------------------------------
# Database Migration (migrate.py)
# -----------------------------------------------------------------------------

# Action to run: "up" or "down"
MIGRATION_ACTION=up
